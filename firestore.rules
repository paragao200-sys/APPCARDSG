    function isValidPreset(data) {
      return data.name is string && data.name.size() <= 64
        && data.banca is string && data.banca.size() <= 20
        && data.meta is string && data.meta.size() <= 10
        && data.stopLoss is string && data.stopLoss.size() <= 10
        && data.strategy in ['CONSERVATIVE', 'AGGRESSIVE']
        && data.userId == request.auth.uid
        && data.createdAt is number;
    }

    match /presets/{presetId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && isValidPreset(request.resource.data);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && isValidPreset(request.resource.data);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
